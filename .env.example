# Copy selected names into a protected environment file outside the repository.
# Values below are synthetic placeholders, never working OCI identifiers.
OCI_A1_HUNTER_OCI_CONFIG=/path/to/oci/config
OCI_A1_HUNTER_OCI_PROFILE=DEFAULT
OCI_A1_HUNTER_COMPARTMENT_ID=<compartment-identifier>
OCI_A1_HUNTER_AVAILABILITY_DOMAIN=<availability-domain>
OCI_A1_HUNTER_SUBNET_ID=<subnet-identifier>
OCI_A1_HUNTER_IMAGE_ID=<image-identifier>
OCI_A1_HUNTER_SHAPE=VM.Standard.A1.Flex
OCI_A1_HUNTER_OCPUS=1
OCI_A1_HUNTER_MEMORY_GB=6
OCI_A1_HUNTER_DISPLAY_NAME=sagneo-a1-hunter
OCI_A1_HUNTER_SSH_PUBLIC_KEY=/path/to/public/key
OCI_A1_HUNTER_PROJECT_TAG=sagneo-a1-hunter
OCI_A1_HUNTER_MAX_ATTEMPTS=5
OCI_A1_HUNTER_MIN_DELAY=30
OCI_A1_HUNTER_MAX_DELAY=120
OCI_A1_HUNTER_STATE_DIR=/var/lib/oci-a1-flex-hunter
OCI_A1_HUNTER_LOG_LEVEL=INFO

